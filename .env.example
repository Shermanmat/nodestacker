# NodeStacker Environment Variables

# Database
DATABASE_PATH=nodestacker.db

# Server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Admin
ADMIN_EMAIL=mat@matsherman.com

# Postmark (Email)
POSTMARK_API_KEY=your_postmark_api_key
POSTMARK_FROM_EMAIL=mat@matsherman.com

# Anthropic (AI - for onboarding chat and research)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Dropbox Sign (E-Signature) - for advisory agreements
DROPBOX_SIGN_API_KEY=your_dropbox_sign_api_key
DROPBOX_SIGN_CLIENT_ID=your_dropbox_sign_client_id
DROPBOX_SIGN_TEMPLATE_ID=your_advisory_agreement_template_id

# Google Drive (Document Storage)
# Base64-encoded JSON service account key
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json
# Folder IDs from Google Drive
GOOGLE_DRIVE_ONBOARDING_FOLDER_ID=folder_id_for_onboarding_companies
GOOGLE_DRIVE_COMPLETED_FOLDER_ID=folder_id_for_fully_onboarded_companies
